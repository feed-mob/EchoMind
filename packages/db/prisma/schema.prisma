// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups    GroupMember[]
  ideas     Idea[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  department  String?
  icon        String?
  logo        String?
  description String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  ideas       Idea[]
  goals       Goal[]
  aiEvaluationSettings AiEvaluationSetting[]
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Idea {
  id          String   @id @default(cuid())
  title       String
  content     String?
  status      String   @default("pending")
  groupId     String
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  aiEvaluationResults AiEvaluationResult[]
}

model Goal {
  id             String   @id @default(cuid())
  title          String
  description    String?
  status         String   @default("draft")
  successMetrics Json?
  constraints    Json?
  groupId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group          Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  aiEvaluationSettings AiEvaluationSetting[]
}

model AiEvaluationSetting {
  id              String   @id @default(cuid())
  groupId         String
  goalId          String
  model           String
  impactWeight    Int
  feasibilityWeight Int
  originalityWeight Int
  selectedIdeaIds Json
  createdAt       DateTime @default(now())

  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  goal            Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  results         AiEvaluationResult[]

  @@index([groupId, createdAt(sort: Desc)])
  @@index([goalId])
}

model AiEvaluationResult {
  id                String   @id @default(cuid())
  settingId         String
  ideaId            String
  review            String
  impactScore       Int
  feasibilityScore  Int
  originalityScore  Int
  totalScore        Int
  rank              Int
  createdAt         DateTime @default(now())

  setting           AiEvaluationSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  idea              Idea                @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([settingId, ideaId])
  @@index([settingId, rank])
}
