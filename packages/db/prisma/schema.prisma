// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups    GroupMember[]
  ideas     Idea[]
  goals     Goal[]   @relation("GoalCreator")
  comments  Comment[]
  invitations GroupInvitation[] @relation("InvitedByUser")
  moods Mood[]
  moodDailySummaries MoodDailySummary[]
  moodRedemptions MoodRedemption[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  department  String?
  icon        String?
  logo        String?
  description String?
  status      String   @default("active")
  publicAccessEnabled   Boolean @default(false)
  aiCollaborationEnabled Boolean @default(true)
  workspaceVisibility   String  @default("Members only")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  ideas       Idea[]
  goals       Goal[]
  aiEvaluationSettings AiEvaluationSetting[]
  invitations GroupInvitation[]
}

model GroupInvitation {
  id             String   @id
  groupId        String
  email          String
  invitedByUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group          Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedByUser  User?    @relation("InvitedByUser", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([groupId, email])
  @@index([email])
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Idea {
  id          String   @id @default(cuid())
  title       String
  content     String?
  status      String   @default("pending")
  groupId     String
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  aiEvaluationResults AiEvaluationResult[]
  selectedInGoals Goal[] @relation("GoalSelectedIdea")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  ideaId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ideaId, createdAt(sort: Desc)])
  @@index([authorId])
}

model Goal {
  id             String   @id @default(cuid())
  title          String
  description    String?
  status         String   @default("draft")
  successMetrics Json?
  constraints    Json?
  creatorId      String
  selectedIdeaId String?
  selectedSettingId String?
  groupId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group          Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  creator        User     @relation("GoalCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  selectedIdea   Idea?    @relation("GoalSelectedIdea", fields: [selectedIdeaId], references: [id], onDelete: SetNull)
  selectedSetting AiEvaluationSetting? @relation("GoalSelectedSetting", fields: [selectedSettingId], references: [id], onDelete: SetNull)
  aiEvaluationSettings AiEvaluationSetting[] @relation("GoalEvaluationSettings")

  @@index([creatorId])
  @@index([selectedIdeaId])
  @@index([selectedSettingId])
}

model AiEvaluationSetting {
  id              String   @id @default(cuid())
  groupId         String
  goalId          String
  model           String
  impactWeight    Int
  feasibilityWeight Int
  originalityWeight Int
  selectedIdeaIds Json
  createdAt       DateTime @default(now())

  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  goal            Goal     @relation("GoalEvaluationSettings", fields: [goalId], references: [id], onDelete: Cascade)
  results         AiEvaluationResult[]
  selectedByGoals Goal[]   @relation("GoalSelectedSetting")

  @@index([groupId, createdAt(sort: Desc)])
  @@index([goalId])
}

model AiEvaluationResult {
  id                String   @id @default(cuid())
  settingId         String
  ideaId            String
  review            String
  impactScore       Int
  feasibilityScore  Int
  originalityScore  Int
  totalScore        Int
  rank              Int
  createdAt         DateTime @default(now())

  setting           AiEvaluationSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  idea              Idea                @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([settingId, ideaId])
  @@index([settingId, rank])
}

model Mood {
  id          String   @id @default(cuid())
  userId      String
  mood        String   // awesome, good, neutral, low, poor
  sentiment   String   // positive, negative, neutral (新增：归类到三大类型)
  emotion     String?  // joyful, calm, anxious, stressed, etc.
  notes       String?
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 情绪光谱系统 Emotion Spectrum System
  spectrum    String?  // stress, boredom, anxiety, anger, joy, achievement, warmth, calm
  color       String?  // hex color code: gray, lightGray, darkBlue, red, orange, gold, pink, green
  icon        String?  // trash, cloud, flame, candy, star, lamp, leaf
  intensity   Int?     // 1-10, emotion intensity level

  // 关联到每日汇总
  dailySummary MoodDailySummary? @relation(fields: [dailySummaryId], references: [id])
  dailySummaryId String?

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId])
  @@index([spectrum])
  @@index([sentiment, dailySummaryId]) // 查询未汇总的某类型心情
}

model MoodDailySummary {
  id          String   @id @default(cuid())
  userId      String
  date        DateTime @db.Date  // 日期（不含时间）

  // 当天情绪归类
  sentiment   String   // positive, negative, neutral

  // 兑换状态
  isRedeemed  Boolean  @default(false) // 是否已兑换/倾倒
  redeemedAt  DateTime?
  redemptionType String? // reward, dump

  // 统计
  totalMoods  Int      @default(0) // 当天记录条数

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关联
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moods       Mood[]

  @@unique([userId, date]) // 每天唯一
  @@index([userId, date])
  @@index([sentiment, isRedeemed, userId]) // 查询某用户未兑换的某类型
}

model MoodRedemption {
  id          String   @id @default(cuid())
  userId      String

  // 兑换类型
  type        String   // reward(兑换奖励), dump(倾倒释放)

  // 兑换的心情类型
  sentiment   String   // positive, negative

  // 等级系统（多余积攒升级）
  level       Int      @default(1) // 1=基础, 2=进阶, 3=豪华...

  // 消耗统计
  baseCount   Int      // 基础需求（积极7，不积极3）
  extraCount  Int      @default(0) // 多余升级的数量
  totalCount  Int      // 总共消耗（清零）

  // 奖励描述
  reward      String?  // 奖励描述

  createdAt   DateTime @default(now())

  // 关联
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([sentiment])
}
