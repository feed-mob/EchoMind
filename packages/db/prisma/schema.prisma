// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groups    GroupMember[]
  ideas     Idea[]
  comments  Comment[]
  invitations GroupInvitation[] @relation("InvitedByUser")
  moods Mood[]
}

model Group {
  id          String   @id @default(cuid())
  name        String
  department  String?
  icon        String?
  logo        String?
  description String?
  status      String   @default("active")
  publicAccessEnabled   Boolean @default(false)
  aiCollaborationEnabled Boolean @default(true)
  workspaceVisibility   String  @default("Members only")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members     GroupMember[]
  ideas       Idea[]
  goals       Goal[]
  aiEvaluationSettings AiEvaluationSetting[]
  invitations GroupInvitation[]
}

model GroupInvitation {
  id             String   @id
  groupId        String
  email          String
  invitedByUserId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group          Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  invitedByUser  User?    @relation("InvitedByUser", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@unique([groupId, email])
  @@index([email])
}

model GroupMember {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      String   @default("member")
  joinedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
}

model Idea {
  id          String   @id @default(cuid())
  title       String
  content     String?
  status      String   @default("pending")
  groupId     String
  authorId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  group       Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments    Comment[]
  aiEvaluationResults AiEvaluationResult[]
  selectedInGoals Goal[] @relation("GoalSelectedIdea")
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  ideaId    String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([ideaId, createdAt(sort: Desc)])
  @@index([authorId])
}

model Goal {
  id             String   @id @default(cuid())
  title          String
  description    String?
  status         String   @default("draft")
  successMetrics Json?
  constraints    Json?
  selectedIdeaId String?
  selectedSettingId String?
  groupId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  group          Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  selectedIdea   Idea?    @relation("GoalSelectedIdea", fields: [selectedIdeaId], references: [id], onDelete: SetNull)
  selectedSetting AiEvaluationSetting? @relation("GoalSelectedSetting", fields: [selectedSettingId], references: [id], onDelete: SetNull)
  aiEvaluationSettings AiEvaluationSetting[] @relation("GoalEvaluationSettings")

  @@index([selectedIdeaId])
  @@index([selectedSettingId])
}

model AiEvaluationSetting {
  id              String   @id @default(cuid())
  groupId         String
  goalId          String
  model           String
  impactWeight    Int
  feasibilityWeight Int
  originalityWeight Int
  selectedIdeaIds Json
  createdAt       DateTime @default(now())

  group           Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  goal            Goal     @relation("GoalEvaluationSettings", fields: [goalId], references: [id], onDelete: Cascade)
  results         AiEvaluationResult[]
  selectedByGoals Goal[]   @relation("GoalSelectedSetting")

  @@index([groupId, createdAt(sort: Desc)])
  @@index([goalId])
}

model AiEvaluationResult {
  id                String   @id @default(cuid())
  settingId         String
  ideaId            String
  review            String
  impactScore       Int
  feasibilityScore  Int
  originalityScore  Int
  totalScore        Int
  rank              Int
  createdAt         DateTime @default(now())

  setting           AiEvaluationSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  idea              Idea                @relation(fields: [ideaId], references: [id], onDelete: Cascade)

  @@unique([settingId, ideaId])
  @@index([settingId, rank])
}

model Mood {
  id          String   @id @default(cuid())
  userId      String
  mood        String   // awesome, good, neutral, low, poor
  emotion     String?  // joyful, calm, anxious, stressed, etc.
  notes       String?
  recordedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, recordedAt])
  @@index([userId])
}
